#!/usr/bin/env bash
# Auto-bumps the version for any platform whose source files are staged.
#
# Bump level is controlled by the BUMP env var (default: patch):
#   git commit -m "fix: ..."              # patch  1.2.3 → 1.2.4
#   BUMP=minor git commit -m "feat: ..."  # minor  1.2.3 → 1.3.0
#   BUMP=major git commit -m "..."        # major  1.2.3 → 2.0.0
#
# Targets:
#   macOS:   version/macos.json + src/macos/project.yml (MARKETING_VERSION)
#   Windows: version/windows.json + src/windows-native/LanMessenger/LanMessenger.csproj
#
# Install: cp scripts/hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
BUMP="${BUMP:-patch}"

case "$BUMP" in
    patch|minor|major) ;;
    *) echo "pre-commit: invalid BUMP value '$BUMP' (use patch, minor, or major)" >&2; exit 1 ;;
esac

bump_version() {
    local version="$1"
    local level="$2"
    local IFS='.'
    read -ra parts <<< "$version"

    local major="${parts[0]:-0}"
    local minor="${parts[1]:-0}"
    local patch="${parts[2]:-0}"

    case "$level" in
        major) echo "$(( major + 1 )).0.0" ;;
        minor) echo "$major.$(( minor + 1 )).0" ;;
        patch) echo "$major.$minor.$(( patch + 1 ))" ;;
    esac
}

json_version() {
    python3 -c "import json,sys; print(json.load(open(sys.argv[1]))['version'])" "$1"
}

write_json_version() {
    python3 -c "
import json, sys
path, ver = sys.argv[1], sys.argv[2]
with open(path) as f:
    d = json.load(f)
d['version'] = ver
with open(path, 'w') as f:
    json.dump(d, f)
    f.write('\n')
" "$1" "$2"
}

# Only examine source files — skip version files themselves to avoid double-bumping
# when the user manually stages a version update.
# `|| true` prevents grep's exit-1-on-no-match from aborting the script under set -e.
STAGED=$(git diff --cached --name-only | grep -v '^version/' || true)

BUMP_MACOS=0
BUMP_WINDOWS=0

while IFS= read -r file; do
    [[ -z "$file" ]] && continue
    [[ "$file" == src/macos/* ]] && BUMP_MACOS=1
    [[ "$file" == src/windows-native/* ]] && BUMP_WINDOWS=1
done <<< "$STAGED"

if [[ $BUMP_MACOS -eq 1 ]]; then
    MACOS_JSON="$REPO_ROOT/version/macos.json"
    current=$(json_version "$MACOS_JSON")
    next=$(bump_version "$current" "$BUMP")
    write_json_version "$MACOS_JSON" "$next"

    # Sync MAJOR.MINOR into project.yml (Xcode MARKETING_VERSION omits patch)
    major_minor="${next%.*}"
    PROJECT_YML="$REPO_ROOT/src/macos/project.yml"
    sed -i '' "s/MARKETING_VERSION: \"[0-9][0-9.]*\"/MARKETING_VERSION: \"$major_minor\"/" "$PROJECT_YML"

    git add "$MACOS_JSON" "$PROJECT_YML"
    echo "  [version] macOS ($BUMP): $current → $next"
fi

if [[ $BUMP_WINDOWS -eq 1 ]]; then
    WIN_JSON="$REPO_ROOT/version/windows.json"
    current=$(json_version "$WIN_JSON")
    next=$(bump_version "$current" "$BUMP")
    write_json_version "$WIN_JSON" "$next"

    # Sync into .csproj <Version> tag
    CSPROJ="$REPO_ROOT/src/windows-native/LanMessenger/LanMessenger.csproj"
    sed -i '' "s|<Version>[0-9][0-9.]*</Version>|<Version>$next</Version>|" "$CSPROJ"

    git add "$WIN_JSON" "$CSPROJ"
    echo "  [version] Windows ($BUMP): $current → $next"
fi
