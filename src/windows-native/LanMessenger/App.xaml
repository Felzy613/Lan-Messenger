<Application
    x:Class="LanMessenger.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- App palette. ThemeResource lookups against these switch live
                 with the system theme; the code-behind palette (UI/Theme.cs)
                 mirrors the same colors for brushes assigned from C#. -->
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="AppChatBackgroundBrush"    Color="#E5DDD5" />
                    <SolidColorBrush x:Key="AppReplyAccentBrush"       Color="#25D366" />
                    <SolidColorBrush x:Key="AppReplyAccentTextBrush"   Color="#128C4E" />
                    <SolidColorBrush x:Key="AppOnlineDotStrokeBrush"   Color="#FFFFFF" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="AppChatBackgroundBrush"    Color="#0D1418" />
                    <SolidColorBrush x:Key="AppReplyAccentBrush"       Color="#25D366" />
                    <SolidColorBrush x:Key="AppReplyAccentTextBrush"   Color="#25D366" />
                    <SolidColorBrush x:Key="AppOnlineDotStrokeBrush"   Color="#111B21" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="HighContrast">
                    <SolidColorBrush x:Key="AppChatBackgroundBrush"    Color="{ThemeResource SystemColorWindowColor}" />
                    <SolidColorBrush x:Key="AppReplyAccentBrush"       Color="{ThemeResource SystemColorHighlightColor}" />
                    <SolidColorBrush x:Key="AppReplyAccentTextBrush"   Color="{ThemeResource SystemColorHighlightColor}" />
                    <SolidColorBrush x:Key="AppOnlineDotStrokeBrush"   Color="{ThemeResource SystemColorWindowColor}" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <!-- Neutral hover/press fills for round icon buttons — alpha grays
                 read as a subtle highlight on both light and dark backgrounds,
                 unlike the previous alpha-black which vanished in dark mode. -->
            <SolidColorBrush x:Key="AppIconHoverBrush"   Color="#2E808080" />
            <SolidColorBrush x:Key="AppIconPressedBrush" Color="#46808080" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
