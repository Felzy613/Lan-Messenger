<UserControl
    x:Class="LanMessenger.UI.AvatarControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="RootGrid" Width="40" Height="40" CornerRadius="20">
        <Ellipse x:Name="BackgroundEllipse" Width="40" Height="40" />
        <TextBlock x:Name="InitialsText"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="14"
                   FontWeight="SemiBold"
                   Foreground="White" />
    </Grid>
</UserControl>
