<Page
    x:Class="LanMessenger.UI.Sidebar.ArchivedPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:LanMessenger.UI.Sidebar"
    xmlns:ui="using:LanMessenger.UI">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE7B8;"
                      VerticalAlignment="Center" FontSize="20" />
            <TextBlock Text="Archived" Style="{ThemeResource TitleTextBlockStyle}" />
        </StackPanel>

        <ListView x:Name="ArchivedList" Grid.Row="1" SelectionMode="None">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="8,6" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:ConversationRowViewModel">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:AvatarControl Grid.Column="0" Width="40" Height="40"
                                          NameText="{x:Bind PeerName, Mode=OneWay}"
                                          PhotoB64="{x:Bind PhotoB64, Mode=OneWay}" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="{x:Bind PeerName, Mode=OneWay}"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="{x:Bind LastMessage, Mode=OneWay}"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <Button Grid.Column="2" Content="Open"
                                Tag="{x:Bind PeerIP}" Click="OpenBtn_Click" />
                        <Button Grid.Column="3" Margin="6,0,0,0"
                                Content="Unarchive"
                                Tag="{x:Bind PeerIP}" Click="UnarchiveBtn_Click" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock x:Name="EmptyState" Grid.Row="1"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Text="Nothing archived"
                   Style="{ThemeResource SubtitleTextBlockStyle}"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   Visibility="Collapsed" />
    </Grid>
</Page>
