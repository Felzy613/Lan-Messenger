<UserControl
    x:Class="LanMessenger.UI.Sidebar.ConversationRowControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="using:LanMessenger.UI">

    <Grid Padding="4,6" ColumnSpacing="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Avatar with online dot -->
        <Grid Grid.Column="0">
            <ui:AvatarControl x:Name="Avatar" Width="40" Height="40" />
            <!-- Online indicator dot -->
            <Ellipse x:Name="OnlineDot"
                     Width="10" Height="10"
                     Fill="{ThemeResource AccentFillColorDefaultBrush}"
                     Stroke="White" StrokeThickness="2"
                     HorizontalAlignment="Right" VerticalAlignment="Bottom"
                     Visibility="Collapsed" />
        </Grid>

        <!-- Name + preview -->
        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
            <TextBlock x:Name="NameText"
                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                       TextTrimming="CharacterEllipsis" />
            <TextBlock x:Name="PreviewText"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextTrimming="CharacterEllipsis" />
        </StackPanel>

        <!-- Timestamp + unread badge -->
        <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="4">
            <TextBlock x:Name="TimestampText"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                       HorizontalAlignment="Right" />
            <Border x:Name="UnreadBadge"
                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                    CornerRadius="10"
                    MinWidth="20" Height="20"
                    Padding="4,0"
                    HorizontalAlignment="Right"
                    Visibility="Collapsed">
                <TextBlock x:Name="UnreadCount"
                           Foreground="White"
                           FontSize="11"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
