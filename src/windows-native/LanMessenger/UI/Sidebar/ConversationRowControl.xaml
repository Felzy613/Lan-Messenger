<UserControl
    x:Class="LanMessenger.UI.Sidebar.ConversationRowControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="using:LanMessenger.UI">

    <Grid Padding="4,6" ColumnSpacing="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Avatar with online dot (always visible; color set by code-behind) -->
        <Grid Grid.Column="0">
            <ui:AvatarControl x:Name="Avatar" Width="44" Height="44" />
            <Ellipse x:Name="OnlineDot"
                     Width="11" Height="11"
                     Fill="#25D366"
                     Stroke="{ThemeResource AppOnlineDotStrokeBrush}" StrokeThickness="2"
                     HorizontalAlignment="Right" VerticalAlignment="Bottom" />
        </Grid>

        <!-- Name + preview -->
        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
            <TextBlock x:Name="NameText"
                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                       TextTrimming="CharacterEllipsis" />
            <TextBlock x:Name="PreviewText"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextTrimming="CharacterEllipsis" />
        </StackPanel>

        <!-- Timestamp + unread badge -->
        <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="4">
            <TextBlock x:Name="TimestampText"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                       HorizontalAlignment="Right" />
            <Border x:Name="UnreadBadge"
                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                    CornerRadius="10"
                    MinWidth="20" Height="20"
                    Padding="4,0"
                    HorizontalAlignment="Right"
                    Visibility="Collapsed">
                <TextBlock x:Name="UnreadCount"
                           Foreground="White"
                           FontSize="11"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Border>
        </StackPanel>

        <!-- Three-dot conversation options menu -->
        <Button x:Name="OptionsBtn"
                Grid.Column="3"
                Background="Transparent"
                BorderBrush="Transparent"
                Padding="6"
                MinWidth="32"
                Click="OptionsBtn_Click"
                VerticalAlignment="Center"
                ToolTipService.ToolTip="Conversation options">
            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                      Glyph="&#xE712;"
                      FontSize="14" />
            <Button.Flyout>
                <MenuFlyout x:Name="OptionsFlyout">
                    <MenuFlyoutItem x:Name="ArchiveItem" Text="Archive" Click="Archive_Click">
                        <MenuFlyoutItem.Icon>
                            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE7B8;" />
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem x:Name="UnarchiveItem" Text="Unarchive" Click="Unarchive_Click" Visibility="Collapsed">
                        <MenuFlyoutItem.Icon>
                            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE74A;" />
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Delete conversation" Click="Delete_Click">
                        <MenuFlyoutItem.Icon>
                            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE74D;" />
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                </MenuFlyout>
            </Button.Flyout>
        </Button>
    </Grid>
</UserControl>
