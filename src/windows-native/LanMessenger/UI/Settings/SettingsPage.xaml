<Page
    x:Class="LanMessenger.UI.Settings.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Padding="32,24" Spacing="20" MaxWidth="640">
            <TextBlock Text="Settings"
                       Style="{ThemeResource TitleTextBlockStyle}" />

            <!-- Username -->
            <StackPanel Spacing="6">
                <TextBlock Text="Display name"
                           Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <TextBox x:Name="UsernameBox"
                         PlaceholderText="Your name"
                         LostFocus="UsernameBox_LostFocus" />
            </StackPanel>

            <!-- Inbox directory -->
            <StackPanel Spacing="6">
                <TextBlock Text="Received files folder"
                           Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="InboxBox"
                             Grid.Column="0"
                             IsReadOnly="True" />
                    <Button Grid.Column="1"
                            Content="Browse…"
                            Click="BrowseInbox_Click" />
                </Grid>
            </StackPanel>

            <!-- Background behavior -->
            <StackPanel Spacing="6">
                <TextBlock Text="Background"
                           Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <ToggleSwitch x:Name="CloseToTrayToggle"
                              Header="Keep running in the background when window is closed"
                              OnContent="On"
                              OffContent="Off"
                              Toggled="CloseToTrayToggle_Toggled" />
            </StackPanel>

            <!-- Logging -->
            <StackPanel Spacing="6">
                <TextBlock Text="Logging"
                           Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <ToggleSwitch x:Name="VerboseLoggingToggle"
                              Header="Verbose logging (file transfers, peer events, screenshots)"
                              OnContent="On"
                              OffContent="Off"
                              Toggled="VerboseLoggingToggle_Toggled" />
                <TextBlock Text="Useful when reporting a bug — the export contains the active and rotated log files."
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Open Logs Folder" Click="OpenLogsFolder_Click" />
                    <Button Content="Export Logs…" Click="ExportLogs_Click" />
                    <TextBlock x:Name="LogExportStatus"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </StackPanel>

            <!-- Cloud Relay -->
            <StackPanel Spacing="6">
                <TextBlock Text="Cloud Relay"
                           Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <ToggleSwitch x:Name="RelayEnabledToggle"
                              Header="Enable cloud relay"
                              OnContent="On"
                              OffContent="Off"
                              Toggled="RelayEnabledToggle_Toggled" />
                <TextBlock Text="When enabled, messages sent to offline contacts are stored in the cloud and delivered when they reconnect. Deploy your own Cloudflare Worker (see README) and paste its URL below."
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap" />
                <TextBox x:Name="RelayUrlBox"
                         Header="Worker URL"
                         PlaceholderText="https://your-worker.workers.dev"
                         LostFocus="RelayUrlBox_LostFocus" />
            </StackPanel>

            <!-- Updates -->
            <StackPanel Spacing="6">
                <TextBlock Text="Updates"
                           Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <TextBox x:Name="UpdateRepoBox"
                         Header="GitHub repository (owner/repo)"
                         PlaceholderText="felzy613/lan-messenger"
                         LostFocus="UpdateRepoBox_LostFocus" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Name="CheckUpdatesBtn"
                            Content="Check Now"
                            Click="CheckUpdates_Click" />
                    <TextBlock x:Name="UpdateStatusText"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <Border x:Name="UpdatePanel"
                        BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12"
                        Visibility="Collapsed">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xEBD3;"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                            <TextBlock x:Name="UpdateAvailableText"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}" />
                            <Button x:Name="InstallNowBtn"
                                    Content="Install &amp; Restart"
                                    Style="{ThemeResource AccentButtonStyle}"
                                    Click="InstallNow_Click" />
                        </StackPanel>
                        <!-- Release notes rendered as Markdown (headings, lists, bold,
                             inline code, links).  Collapsed to ~5 lines initially;
                             "Show more" expands into a scrollable area. -->
                        <ScrollViewer x:Name="UpdateNotesScroll"
                                      MaxHeight="120"
                                      VerticalScrollBarVisibility="Hidden">
                            <RichTextBlock x:Name="UpdateNotesBlock"
                                           TextWrapping="Wrap"
                                           IsTextSelectionEnabled="True"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </ScrollViewer>
                        <Button x:Name="NotesToggleBtn"
                                Content="Show more"
                                Padding="0"
                                BorderThickness="0"
                                Background="Transparent"
                                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                Visibility="Collapsed"
                                Click="NotesToggleBtn_Click" />
                        <ProgressBar x:Name="UpdateProgressBar"
                                     Value="0"
                                     Minimum="0"
                                     Maximum="1"
                                     Visibility="Collapsed" />
                        <TextBlock x:Name="UpdateProgressText"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Visibility="Collapsed" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Version -->
            <StackPanel Spacing="6">
                <TextBlock Text="About"
                           Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <TextBlock x:Name="VersionText"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
