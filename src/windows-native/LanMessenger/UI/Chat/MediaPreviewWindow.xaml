<Window
    x:Class="LanMessenger.UI.Chat.MediaPreviewWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="">

    <!--
        Three-row media viewer rendered as a standalone centered window.

          Row 0  — dark top bar    (#1F2C34): filename + date/time · show-in-folder · caption-button reserve
          Row 1  — black media area (#000000): Image / MediaPlayerElement / error panel
          Row 2  — dark bottom bar (#1F2C34): file-type · file-size metadata

        ExtendsContentIntoTitleBar = true is set in the code-behind so the dark
        top bar covers the full window width.  The system close button overlays
        the CaptionButtonsCol column; its width is updated in OnActivated once
        AppWindow.TitleBar.RightInset is known.
    -->
    <Grid x:Name="ContentHost" MinWidth="400" MinHeight="332">

        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="Escape" Invoked="OnEscapeInvoked"/>
        </Grid.KeyboardAccelerators>

        <Grid.RowDefinitions>
            <RowDefinition Height="46"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="48"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════ TOP BAR ═══════════════════════ -->
        <Grid x:Name="TopBarGrid"
              Grid.Row="0"
              Background="#1F2C34"
              Padding="16,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>   <!-- show-in-folder -->
                <ColumnDefinition Width="*"/>      <!-- filename + date -->
                <ColumnDefinition x:Name="CaptionButtonsCol" Width="46"/>  <!-- reserved for system close -->
            </Grid.ColumnDefinitions>

            <!-- Show-in-folder -->
            <Button Grid.Column="0"
                    x:Name="ShowInFolderBtn"
                    Width="36" Height="36"
                    Padding="0"
                    Margin="0,0,8,0"
                    CornerRadius="18"
                    BorderThickness="0"
                    ToolTipService.ToolTip="Show in folder"
                    Click="ShowInFolderBtn_Click">
                <Button.Resources>
                    <SolidColorBrush x:Key="ButtonBackground"             Color="Transparent"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver"  Color="#22FFFFFF"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPressed"      Color="#33FFFFFF"/>
                    <SolidColorBrush x:Key="ButtonBorderBrush"            Color="Transparent"/>
                    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent"/>
                    <SolidColorBrush x:Key="ButtonBorderBrushPressed"     Color="Transparent"/>
                </Button.Resources>
                <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                          Glyph="&#xE8DA;"
                          FontSize="16"
                          Foreground="White"/>
            </Button>

            <!-- Filename (bold) + date/time (secondary) stacked -->
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Spacing="10">
                <TextBlock x:Name="FilenameText"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="White"
                           TextTrimming="CharacterEllipsis"
                           MaxLines="1"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="DateText"
                           FontSize="12"
                           Foreground="#8696A0"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Empty column reserved for the system close button overlay -->
            <Grid Grid.Column="2"/>
        </Grid>

        <!-- ═══════════════════════ MEDIA AREA ═══════════════════════ -->
        <Grid Grid.Row="1" Background="Black">

            <!-- Image viewer — full resolution, letter-boxed -->
            <Image x:Name="PreviewImage"
                   Stretch="Uniform"
                   Visibility="Collapsed"/>

            <!-- Video player — built-in transport controls, auto-plays on open -->
            <MediaPlayerElement x:Name="PreviewPlayer"
                                AreTransportControlsEnabled="True"
                                AutoPlay="True"
                                Stretch="Uniform"
                                Visibility="Collapsed"/>

            <!-- Error / unsupported-format state -->
            <StackPanel x:Name="ErrorPanel"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="16"
                        Visibility="Collapsed">
                <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                          Glyph="&#xE814;"
                          FontSize="48"
                          Foreground="#4D8696A0"/>
                <TextBlock x:Name="ErrorText"
                           FontSize="14"
                           Foreground="#8696A0"
                           TextAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- ═══════════════════════ BOTTOM BAR ═══════════════════════ -->
        <Grid Grid.Row="2"
              Background="#1F2C34"
              Padding="20,0">
            <TextBlock x:Name="FileInfoText"
                       FontSize="12"
                       Foreground="#8696A0"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>
        </Grid>
    </Grid>
</Window>
