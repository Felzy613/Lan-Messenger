<UserControl
    x:Class="LanMessenger.UI.Chat.MessageBubbleControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid x:Name="RootGrid" Padding="0,2">
        <Border x:Name="Bubble"
                CornerRadius="10"
                Padding="9,6,9,5"
                MaxWidth="520"
                HorizontalAlignment="Left">
            <Border.ContextFlyout>
                <MenuFlyout x:Name="BubbleMenu">
                    <MenuFlyoutItem Text="Reply" Click="ReplyMenu_Click" />
                    <MenuFlyoutItem Text="Copy" Click="CopyMenu_Click" />
                </MenuFlyout>
            </Border.ContextFlyout>
            <StackPanel Spacing="2">

                <!-- Reply chip -->
                <Border x:Name="ReplyChip"
                        Background="#11000000"
                        CornerRadius="4"
                        Padding="6,4"
                        Margin="0,0,0,4"
                        Tapped="ReplyChip_Tapped"
                        Visibility="Collapsed">
                    <Grid ColumnSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Rectangle Grid.Column="0" Fill="#128C4E" />
                        <StackPanel Grid.Column="1" Spacing="0">
                            <TextBlock x:Name="ReplySender"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="#128C4E" />
                            <TextBlock x:Name="ReplyPreview"
                                       FontSize="11"
                                       Opacity="0.75"
                                       TextTrimming="CharacterEllipsis"
                                       MaxLines="1" />
                        </StackPanel>
                    </Grid>
                </Border>

                <TextBlock x:Name="MessageText"
                           TextWrapping="Wrap"
                           FontSize="14" />
                <Button x:Name="OpenFileBtn"
                        Content="Open file"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        Visibility="Collapsed"
                        Click="OpenFileBtn_Click" />
                <StackPanel Orientation="Horizontal"
                            Spacing="4"
                            HorizontalAlignment="Right"
                            Margin="0,2,0,0">
                    <TextBlock x:Name="TimestampText"
                               FontSize="10"
                               Opacity="0.55" />
                    <!-- Status check marks (text glyphs). -->
                    <TextBlock x:Name="StatusText"
                               FontSize="11"
                               FontFamily="Segoe UI Symbol" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
