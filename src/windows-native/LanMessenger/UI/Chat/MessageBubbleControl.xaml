<UserControl
    x:Class="LanMessenger.UI.Chat.MessageBubbleControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid x:Name="RootGrid" Padding="0,2">
        <Border x:Name="Bubble"
                CornerRadius="16"
                Padding="10,7,10,6"
                MaxWidth="520"
                HorizontalAlignment="Left">
            <Border.ContextFlyout>
                <MenuFlyout x:Name="BubbleMenu">
                    <MenuFlyoutItem Text="Reply" Click="ReplyMenu_Click" />
                    <MenuFlyoutItem Text="Copy"  Click="CopyMenu_Click" />
                    <MenuFlyoutItem x:Name="ShowInExplorerMenu"
                                    Text="Show in folder"
                                    Click="ShowInExplorerMenu_Click"
                                    Visibility="Collapsed" />
                </MenuFlyout>
            </Border.ContextFlyout>
            <StackPanel Spacing="2">

                <!-- Reply chip — shows a thumbnail for image/video replies, a doc
                     icon for file replies, and plain text for text replies. -->
                <Border x:Name="ReplyChip"
                        Background="#11000000"
                        CornerRadius="4"
                        Padding="6,4"
                        Margin="0,0,0,4"
                        Tapped="ReplyChip_Tapped"
                        Visibility="Collapsed">
                    <Grid ColumnSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Rectangle Grid.Column="0" Fill="#128C4E" />
                        <!-- Optional thumbnail / icon for media and file replies -->
                        <Border x:Name="ReplyChipThumbnailBorder"
                                Grid.Column="1"
                                Width="36" Height="36"
                                CornerRadius="4"
                                Background="#22000000"
                                Visibility="Collapsed">
                            <Grid>
                                <Image x:Name="ReplyChipImage"
                                       Stretch="UniformToFill"
                                       Visibility="Collapsed" />
                                <FontIcon x:Name="ReplyChipIcon"
                                          FontFamily="Segoe MDL2 Assets"
                                          FontSize="18"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Foreground="White"
                                          Visibility="Collapsed" />
                            </Grid>
                        </Border>
                        <StackPanel Grid.Column="2" Spacing="0" VerticalAlignment="Center">
                            <TextBlock x:Name="ReplySender"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="#128C4E" />
                            <TextBlock x:Name="ReplyPreview"
                                       FontSize="11"
                                       Opacity="0.75"
                                       TextTrimming="CharacterEllipsis"
                                       MaxLines="1" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Inline image preview (visible only for image MediaKind).
                     MaxWidth caps the bubble width so a 4K image cannot blow out
                     the chat list layout. Tap opens the modal viewer. -->
                <Border x:Name="ImageTile"
                        CornerRadius="10"
                        Visibility="Collapsed"
                        Tapped="MediaTile_Tapped">
                    <Grid>
                        <Image x:Name="ImagePreview"
                               Stretch="Uniform"
                               MaxWidth="280"
                               MaxHeight="280" />
                        <ProgressRing x:Name="ImageProgress"
                                      IsActive="True"
                                      Width="28" Height="28"
                                      Visibility="Collapsed" />
                    </Grid>
                </Border>

                <!-- Inline video tile.  MediaPlayerElement is heavy, so the chat
                     list shows a poster tile (filename + play icon) and the
                     player is only constructed inside the modal preview. -->
                <Border x:Name="VideoTile"
                        CornerRadius="10"
                        Background="#22000000"
                        Padding="10"
                        Visibility="Collapsed"
                        Tapped="MediaTile_Tapped">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0"
                              Width="60" Height="60"
                              Background="#000000"
                              CornerRadius="8">
                            <FontIcon Glyph="&#xE714;"
                                      FontFamily="Segoe MDL2 Assets"
                                      FontSize="28"
                                      Foreground="White"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                        </Grid>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock x:Name="VideoFilename"
                                       FontSize="13" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       MaxLines="1" />
                            <TextBlock Text="Tap to play"
                                       FontSize="11"
                                       Opacity="0.7" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Generic message text — hidden when an inline media tile is shown. -->
                <TextBlock x:Name="MessageText"
                           TextWrapping="Wrap"
                           FontSize="14" />

                <!-- File actions row (visible for non-media file bubbles only).
                     Open launches the file with its default app; "Show in folder"
                     opens Explorer with the file selected. -->
                <StackPanel x:Name="FileActions"
                            Orientation="Horizontal"
                            Spacing="6"
                            Visibility="Collapsed">
                    <Button x:Name="OpenFileBtn"
                            Content="Open"
                            Padding="8,2"
                            Click="OpenFileBtn_Click" />
                    <Button x:Name="ShowInExplorerBtn"
                            Content="Show in folder"
                            Padding="8,2"
                            Click="ShowInExplorerBtn_Click"
                            ToolTipService.ToolTip="Open File Explorer with this file selected" />
                </StackPanel>

                <!-- File-missing footer used when the referenced file no longer
                     exists on disk (moved or deleted after history was written). -->
                <TextBlock x:Name="FileMissingText"
                           Text="File no longer available"
                           FontSize="11"
                           Opacity="0.7"
                           Visibility="Collapsed" />

                <StackPanel Orientation="Horizontal"
                            Spacing="4"
                            HorizontalAlignment="Right"
                            Margin="0,2,0,0">
                    <TextBlock x:Name="TimestampText"
                               FontSize="10"
                               Opacity="0.55" />
                    <!-- Relay delivery badge — hidden for direct LAN messages. -->
                    <StackPanel x:Name="RelayBadge"
                                Orientation="Horizontal"
                                Spacing="2"
                                Visibility="Collapsed"
                                Opacity="0.6">
                        <FontIcon Glyph="&#xE753;"
                                  FontFamily="Segoe MDL2 Assets"
                                  FontSize="9" />
                        <TextBlock Text="via relay"
                                   FontSize="9" />
                    </StackPanel>
                    <!-- Status check marks (text glyphs). -->
                    <TextBlock x:Name="StatusText"
                               FontSize="11"
                               FontFamily="Segoe UI Symbol" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
