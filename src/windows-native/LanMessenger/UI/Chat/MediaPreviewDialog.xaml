<ContentDialog
    x:Class="LanMessenger.UI.Chat.MediaPreviewDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    CornerRadius="0"
    BorderThickness="0"
    Opened="OnOpened">

    <!--
        Strip all built-in ContentDialog chrome so the dialog fills the window
        with a uniform WhatsApp-dark surface.  No Title, no standard buttons.

        ContentDialogMaxWidth/Height are set very large so the content's
        MinWidth/MinHeight (matched to XamlRoot.Size in OnOpened) drives the
        actual size.  Padding, border, corner radius, and the title-area
        overlay are all zeroed out.
    -->
    <ContentDialog.Resources>
        <x:Double        x:Key="ContentDialogMaxWidth">9999</x:Double>
        <x:Double        x:Key="ContentDialogMaxHeight">9999</x:Double>
        <Thickness       x:Key="ContentDialogPadding">0</Thickness>
        <SolidColorBrush x:Key="ContentDialogBackground"           Color="#111B21"/>
        <SolidColorBrush x:Key="ContentDialogBorderBrush"          Color="Transparent"/>
        <Thickness       x:Key="ContentDialogBorderThickness">0</Thickness>
        <CornerRadius    x:Key="ContentDialogCornerRadius">0</CornerRadius>
        <!-- Make the title-overlay band transparent; our top bar replaces it. -->
        <SolidColorBrush x:Key="ContentDialogTopOverlayBackground" Color="Transparent"/>
    </ContentDialog.Resources>

    <!--
        Three-row layout mirrors WhatsApp's media viewer:

          Row 0  — dark top bar    (#1F2C34): × close · filename + date · show-in-folder
          Row 1  — black media area (#000000): Image / MediaPlayerElement / error panel
          Row 2  — dark bottom bar (#1F2C34): file-type · file-size metadata

        MinWidth / MinHeight are expanded to the hosting window bounds in OnOpened.
    -->
    <Grid x:Name="ContentHost" MinWidth="400" MinHeight="332">
        <Grid.RowDefinitions>
            <RowDefinition Height="72"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════ TOP BAR ═══════════════════════ -->
        <Grid Grid.Row="0"
              Background="#1F2C34"
              Padding="4,0,12,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>   <!-- close button -->
                <ColumnDefinition Width="*"/>      <!-- filename + date -->
                <ColumnDefinition Width="Auto"/>   <!-- show-in-folder -->
            </Grid.ColumnDefinitions>

            <!-- Close (×) — left edge -->
            <Button Grid.Column="0"
                    x:Name="CloseBtn"
                    Width="56" Height="56"
                    Margin="0,0,4,0"
                    Padding="0"
                    CornerRadius="28"
                    BorderThickness="0"
                    Click="CloseBtn_Click">
                <Button.Resources>
                    <SolidColorBrush x:Key="ButtonBackground"             Color="Transparent"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver"  Color="#22FFFFFF"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPressed"      Color="#33FFFFFF"/>
                    <SolidColorBrush x:Key="ButtonBorderBrush"            Color="Transparent"/>
                    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent"/>
                    <SolidColorBrush x:Key="ButtonBorderBrushPressed"     Color="Transparent"/>
                </Button.Resources>
                <FontIcon FontFamily="Segoe MDL2 Assets"
                          Glyph="&#xE711;"
                          FontSize="18"
                          Foreground="White"/>
            </Button>

            <!-- Filename (bold) + date/time (secondary) -->
            <StackPanel Grid.Column="1"
                        VerticalAlignment="Center"
                        Spacing="2"
                        Margin="4,0">
                <TextBlock x:Name="FilenameText"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="White"
                           TextTrimming="CharacterEllipsis"
                           MaxLines="1"/>
                <TextBlock x:Name="DateText"
                           FontSize="12"
                           Foreground="#8696A0"/>
            </StackPanel>

            <!-- Show-in-folder — right edge -->
            <Button Grid.Column="2"
                    x:Name="ShowInFolderBtn"
                    Width="48" Height="48"
                    Padding="0"
                    CornerRadius="24"
                    BorderThickness="0"
                    ToolTipService.ToolTip="Show in folder"
                    Click="ShowInFolderBtn_Click">
                <Button.Resources>
                    <SolidColorBrush x:Key="ButtonBackground"             Color="Transparent"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver"  Color="#22FFFFFF"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPressed"      Color="#33FFFFFF"/>
                    <SolidColorBrush x:Key="ButtonBorderBrush"            Color="Transparent"/>
                    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent"/>
                    <SolidColorBrush x:Key="ButtonBorderBrushPressed"     Color="Transparent"/>
                </Button.Resources>
                <!-- FolderOpen glyph (E8DA) in Segoe MDL2 Assets -->
                <FontIcon FontFamily="Segoe MDL2 Assets"
                          Glyph="&#xE8DA;"
                          FontSize="20"
                          Foreground="White"/>
            </Button>
        </Grid>

        <!-- ═══════════════════════ MEDIA AREA ═══════════════════════ -->
        <Grid Grid.Row="1" Background="Black">

            <!-- Image viewer — full resolution, letter-boxed -->
            <Image x:Name="PreviewImage"
                   Stretch="Uniform"
                   Visibility="Collapsed"/>

            <!-- Video player — built-in transport controls, auto-plays on open -->
            <MediaPlayerElement x:Name="PreviewPlayer"
                                AreTransportControlsEnabled="True"
                                AutoPlay="True"
                                Stretch="Uniform"
                                Visibility="Collapsed"/>

            <!-- Error / unsupported-format state -->
            <StackPanel x:Name="ErrorPanel"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="16"
                        Visibility="Collapsed">
                <!-- E814 = ErrorBadge (circle with !) -->
                <FontIcon FontFamily="Segoe MDL2 Assets"
                          Glyph="&#xE814;"
                          FontSize="48"
                          Foreground="#4D8696A0"/>
                <TextBlock x:Name="ErrorText"
                           FontSize="14"
                           Foreground="#8696A0"
                           TextAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- ═══════════════════════ BOTTOM BAR ═══════════════════════ -->
        <Grid Grid.Row="2"
              Background="#1F2C34"
              Padding="20,0">
            <!-- File-type · file-size metadata, centered -->
            <TextBlock x:Name="FileInfoText"
                       FontSize="12"
                       Foreground="#8696A0"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>
        </Grid>
    </Grid>
</ContentDialog>
