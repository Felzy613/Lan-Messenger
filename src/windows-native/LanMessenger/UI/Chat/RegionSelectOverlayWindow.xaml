<Window
    x:Class="LanMessenger.UI.Chat.RegionSelectOverlayWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="">

    <!--
        Full-screen, borderless overlay used for "drag to select a region"
        screenshot capture. The backing image is the already-captured primary
        display screenshot; the user drags a rectangle over it, and the
        code-behind crops the backing bitmap to the selected rect.

        Escape cancels. A plain click (no drag) is treated as "select nothing"
        by the code-behind, which falls back to capturing the whole display.
    -->
    <Grid x:Name="RootGrid"
          Background="Transparent"
          PointerPressed="RootGrid_PointerPressed"
          PointerMoved="RootGrid_PointerMoved"
          PointerReleased="RootGrid_PointerReleased">

        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="Escape" Invoked="OnEscapeInvoked"/>
        </Grid.KeyboardAccelerators>

        <!-- Backing screenshot, dimmed slightly so the selection stands out. -->
        <Image x:Name="BackgroundImage" Stretch="Fill"/>
        <Rectangle Fill="#55000000" IsHitTestVisible="False"/>

        <!-- Selection rectangle — bright outline, undimmed fill via the clipped
             background image shown beneath it. -->
        <Rectangle x:Name="SelectionRect"
                   Stroke="#FF2BD96B"
                   StrokeThickness="2"
                   Fill="Transparent"
                   IsHitTestVisible="False"
                   Visibility="Collapsed"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"/>

        <!-- Hint text shown until the first drag starts. -->
        <Border x:Name="HintBorder"
                Background="#AA000000"
                CornerRadius="6"
                Padding="12,8"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,24,0,0"
                IsHitTestVisible="False">
            <TextBlock Text="Drag to select an area · Click to capture the whole screen · Esc to cancel"
                       Foreground="White"
                       FontSize="13"/>
        </Border>
    </Grid>
</Window>
