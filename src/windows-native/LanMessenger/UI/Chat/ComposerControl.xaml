<UserControl
    x:Class="LanMessenger.UI.Chat.ComposerControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    AllowDrop="True"
    DragOver="OnDragOver"
    Drop="OnDrop">
    <Grid Padding="10,8" ColumnSpacing="8"
          Background="{ThemeResource LayerFillColorDefaultBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Attach button — Segoe MDL2 "Attach" glyph matches the macOS SF Symbol paperclip -->
        <Button x:Name="AttachBtn"
                Grid.Column="0"
                Width="32" Height="32"
                Padding="0"
                CornerRadius="16"
                BorderThickness="0"
                ToolTipService.ToolTip="Attach file"
                Click="AttachBtn_Click">
            <Button.Resources>
                <SolidColorBrush x:Key="ButtonBackground"             Color="Transparent"/>
                <SolidColorBrush x:Key="ButtonBackgroundPointerOver"  Color="#18000000"/>
                <SolidColorBrush x:Key="ButtonBackgroundPressed"      Color="#28000000"/>
                <SolidColorBrush x:Key="ButtonBorderBrush"            Color="Transparent"/>
                <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent"/>
                <SolidColorBrush x:Key="ButtonBorderBrushPressed"     Color="Transparent"/>
            </Button.Resources>
            <FontIcon FontFamily="Segoe MDL2 Assets"
                      Glyph="&#xE723;"
                      FontSize="16"
                      Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </Button>

        <!-- Input box — custom Border keeps the WhatsApp rounded style at all focus states -->
        <Border Grid.Column="1"
                Background="{ThemeResource ControlFillColorDefaultBrush}"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="20"
                Padding="12,4">
            <TextBox x:Name="InputBox"
                     PlaceholderText="Message"
                     AcceptsReturn="False"
                     TextWrapping="Wrap"
                     MinHeight="32"
                     MaxHeight="120"
                     BorderThickness="0"
                     Background="Transparent"
                     VerticalContentAlignment="Center"
                     KeyDown="InputBox_KeyDown"
                     TextChanged="InputBox_TextChanged">
                <!-- Suppress TextBox's own focus/hover chrome so the outer Border stays visible -->
                <TextBox.Resources>
                    <SolidColorBrush x:Key="TextControlBorderBrushFocused"      Color="Transparent"/>
                    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver"  Color="Transparent"/>
                    <SolidColorBrush x:Key="TextControlBackgroundFocused"       Color="Transparent"/>
                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver"   Color="Transparent"/>
                </TextBox.Resources>
            </TextBox>
        </Border>

        <!-- Send button — WhatsApp green circle with up arrow, matching macOS arrow.up.circle.fill -->
        <Button x:Name="SendBtn"
                Grid.Column="2"
                Width="38" Height="38"
                Padding="0"
                CornerRadius="19"
                BorderThickness="0"
                Click="SendBtn_Click"
                ToolTipService.ToolTip="Send">
            <Button.Resources>
                <SolidColorBrush x:Key="ButtonBackground"             Color="#25D366"/>
                <SolidColorBrush x:Key="ButtonBackgroundPointerOver"  Color="#1EBE5D"/>
                <SolidColorBrush x:Key="ButtonBackgroundPressed"      Color="#1AAD54"/>
                <SolidColorBrush x:Key="ButtonForeground"             Color="White"/>
                <SolidColorBrush x:Key="ButtonForegroundPointerOver"  Color="White"/>
                <SolidColorBrush x:Key="ButtonForegroundPressed"      Color="White"/>
                <SolidColorBrush x:Key="ButtonBorderBrush"            Color="Transparent"/>
                <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent"/>
                <SolidColorBrush x:Key="ButtonBorderBrushPressed"     Color="Transparent"/>
            </Button.Resources>
            <FontIcon FontFamily="Segoe MDL2 Assets"
                      Glyph="&#xE74A;"
                      FontSize="14"
                      Foreground="White" />
        </Button>
    </Grid>
</UserControl>
