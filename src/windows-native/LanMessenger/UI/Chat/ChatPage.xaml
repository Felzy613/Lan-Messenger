<Page
    x:Class="LanMessenger.UI.Chat.ChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:LanMessenger.UI.Chat"
    xmlns:ui="using:LanMessenger.UI">

    <Grid Background="#E5DDD5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header: avatar + name + online dot + typing -->
        <Grid Grid.Row="0"
              Padding="16,12"
              ColumnSpacing="12"
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <ui:AvatarControl x:Name="HeaderAvatar" Width="40" Height="40" />
                <Ellipse x:Name="HeaderOnlineDot"
                         Width="11" Height="11"
                         Fill="#25D366"
                         Stroke="White" StrokeThickness="2"
                         HorizontalAlignment="Right" VerticalAlignment="Bottom"
                         Visibility="Collapsed" />
            </Grid>

            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                <TextBlock x:Name="HeaderName"
                           Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <TextBlock x:Name="HeaderSubtext"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Grid>

        <!-- File transfer banner -->
        <local:FileTransferBannerControl x:Name="TransferBanner"
                                          Grid.Row="1"
                                          Visibility="Collapsed" />

        <!-- Messages list -->
        <ScrollViewer x:Name="MessagesScroll"
                      Grid.Row="2"
                      VerticalScrollMode="Enabled"
                      VerticalScrollBarVisibility="Auto"
                      Padding="12,8"
                      Background="#E5DDD5">
            <ItemsControl x:Name="MessagesList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="local:MessageRowViewModel">
                        <local:MessageBubbleControl Row="{Binding}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Reply banner (shown when replying) -->
        <Border x:Name="ReplyBanner"
                Grid.Row="3"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="14,8"
                Visibility="Collapsed">
            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Rectangle Grid.Column="0" Fill="#25D366" />
                <StackPanel Grid.Column="1" Spacing="1">
                    <TextBlock x:Name="ReplyBannerWho"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="#128C4E" />
                    <TextBlock x:Name="ReplyBannerPreview"
                               FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="1" />
                </StackPanel>
                <Button Grid.Column="2"
                        x:Name="CancelReplyBtn"
                        Content="✕"
                        Padding="6,2"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="CancelReplyBtn_Click" />
            </Grid>
        </Border>

        <!-- Composer -->
        <local:ComposerControl x:Name="Composer"
                               Grid.Row="4"
                               BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                               BorderThickness="0,1,0,0" />
    </Grid>
</Page>
