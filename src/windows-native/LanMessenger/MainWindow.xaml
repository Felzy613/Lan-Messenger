<Window
    x:Class="LanMessenger.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sidebar="using:LanMessenger.UI.Sidebar"
    Title="LAN Messenger">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar pane -->
        <Grid Grid.Column="0"
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,0,1,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="LAN Messenger"
                       Style="{StaticResource TitleTextBlockStyle}"
                       Margin="16,16,16,8" />

            <sidebar:SidebarControl x:Name="Sidebar"
                                    Grid.Row="1" />

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        Padding="12,8"
                        Spacing="8">
                <Button x:Name="ContactsBtn"
                        Content="Contacts"
                        Click="ContactsBtn_Click" />
                <Button x:Name="SettingsBtn"
                        Content="⚙"
                        ToolTipService.ToolTip="Settings"
                        Click="SettingsBtn_Click" />
            </StackPanel>
        </Grid>

        <!-- Content area -->
        <Frame x:Name="ContentFrame"
               Grid.Column="1" />

        <!-- Migration prompt dialog -->
        <ContentDialog x:Name="MigrationDialog"
                       Title="Import Existing Account?"
                       PrimaryButtonText="Import Key"
                       SecondaryButtonText="Start Fresh">
            <TextBlock TextWrapping="Wrap">
                A Python LAN Messenger account was found. Import your existing key
                and chat history, or start with a fresh identity?
            </TextBlock>
        </ContentDialog>
    </Grid>
</Window>
