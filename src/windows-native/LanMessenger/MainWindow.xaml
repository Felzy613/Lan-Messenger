<Window
    x:Class="LanMessenger.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sidebar="using:LanMessenger.UI.Sidebar">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar pane -->
        <Grid Grid.Column="0"
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,0,1,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="LAN Messenger"
                       Style="{ThemeResource TitleTextBlockStyle}"
                       Margin="16,16,16,8" />

            <sidebar:SidebarControl x:Name="Sidebar"
                                    Grid.Row="1" />

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        Padding="12,8"
                        Spacing="8">
                <Button x:Name="ContactsBtn"
                        Content="Contacts"
                        Click="ContactsBtn_Click" />
                <Button x:Name="SettingsBtn"
                        Content="Settings"
                        Click="SettingsBtn_Click" />
            </StackPanel>
        </Grid>

        <!-- Content area -->
        <ContentControl x:Name="ContentFrame"
                        Grid.Column="1"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch" />
    </Grid>
</Window>
