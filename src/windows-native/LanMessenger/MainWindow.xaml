<Window
    x:Class="LanMessenger.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sidebar="using:LanMessenger.UI.Sidebar"
    xmlns:tb="using:H.NotifyIcon">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar pane -->
        <Grid Grid.Column="0"
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,0,1,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header: title on left, icon buttons on right — matches macOS toolbar placement -->
            <Grid Grid.Row="0" Padding="16,12,8,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Chats"
                           Style="{ThemeResource TitleTextBlockStyle}"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="2">
                    <Button x:Name="ContactsBtn"
                            Width="36" Height="36"
                            Padding="0"
                            CornerRadius="18"
                            BorderThickness="0"
                            ToolTipService.ToolTip="Contacts"
                            Click="ContactsBtn_Click">
                        <Button.Resources>
                            <SolidColorBrush x:Key="ButtonBackground"             Color="Transparent"/>
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver"  Color="#18000000"/>
                            <SolidColorBrush x:Key="ButtonBackgroundPressed"      Color="#28000000"/>
                            <SolidColorBrush x:Key="ButtonBorderBrush"            Color="Transparent"/>
                            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent"/>
                        </Button.Resources>
                        <FontIcon FontFamily="Segoe MDL2 Assets"
                                  Glyph="&#xE77B;"
                                  FontSize="16" />
                    </Button>
                    <Button x:Name="SettingsBtn"
                            Width="36" Height="36"
                            Padding="0"
                            CornerRadius="18"
                            BorderThickness="0"
                            ToolTipService.ToolTip="Settings"
                            Click="SettingsBtn_Click">
                        <Button.Resources>
                            <SolidColorBrush x:Key="ButtonBackground"             Color="Transparent"/>
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver"  Color="#18000000"/>
                            <SolidColorBrush x:Key="ButtonBackgroundPressed"      Color="#28000000"/>
                            <SolidColorBrush x:Key="ButtonBorderBrush"            Color="Transparent"/>
                            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent"/>
                        </Button.Resources>
                        <FontIcon FontFamily="Segoe MDL2 Assets"
                                  Glyph="&#xE713;"
                                  FontSize="16" />
                    </Button>
                </StackPanel>
            </Grid>

            <sidebar:SidebarControl x:Name="Sidebar"
                                    Grid.Row="1" />
        </Grid>

        <!-- Content area -->
        <ContentControl x:Name="ContentFrame"
                        Grid.Column="1"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch" />

        <!-- System tray icon (lives off-screen but is rendered in the notification area) -->
        <tb:TaskbarIcon x:Name="TrayIcon"
                        ToolTipText="LAN Messenger"
                        NoLeftClickDelay="True"
                        LeftClickCommand="{x:Bind ShowFromTrayCommand, Mode=OneWay}">
            <tb:TaskbarIcon.GeneratedIcon>
                <tb:GeneratedIcon Text="LM"
                                  Foreground="White"
                                  Background="#25D366"
                                  FontFamily="Segoe UI"
                                  FontWeight="Bold" />
            </tb:TaskbarIcon.GeneratedIcon>
            <tb:TaskbarIcon.ContextFlyout>
                <MenuFlyout>
                    <MenuFlyoutItem Text="Open LAN Messenger" Click="TrayOpen_Click" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Quit" Click="TrayQuit_Click" />
                </MenuFlyout>
            </tb:TaskbarIcon.ContextFlyout>
        </tb:TaskbarIcon>
    </Grid>
</Window>
