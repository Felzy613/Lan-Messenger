<Window
    x:Class="LanMessenger.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sidebar="using:LanMessenger.UI.Sidebar"
    xmlns:tb="using:H.NotifyIcon">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar pane -->
        <Grid Grid.Column="0"
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,0,1,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="LAN Messenger"
                       Style="{ThemeResource TitleTextBlockStyle}"
                       Margin="16,16,16,8" />

            <sidebar:SidebarControl x:Name="Sidebar"
                                    Grid.Row="1" />

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        Padding="12,8"
                        Spacing="8">
                <Button x:Name="ContactsBtn"
                        Content="Contacts"
                        Click="ContactsBtn_Click" />
                <Button x:Name="SettingsBtn"
                        Content="Settings"
                        Click="SettingsBtn_Click" />
            </StackPanel>
        </Grid>

        <!-- Content area -->
        <ContentControl x:Name="ContentFrame"
                        Grid.Column="1"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch" />

        <!-- System tray icon (lives off-screen but is rendered in the notification area) -->
        <tb:TaskbarIcon x:Name="TrayIcon"
                        ToolTipText="LAN Messenger"
                        NoLeftClickDelay="True"
                        LeftClickCommand="{x:Bind ShowFromTrayCommand, Mode=OneWay}">
            <tb:TaskbarIcon.GeneratedIcon>
                <tb:GeneratedIcon Text="LM"
                                  Foreground="White"
                                  Background="#25D366"
                                  FontFamily="Segoe UI"
                                  FontWeight="Bold" />
            </tb:TaskbarIcon.GeneratedIcon>
            <tb:TaskbarIcon.ContextFlyout>
                <MenuFlyout>
                    <MenuFlyoutItem Text="Open LAN Messenger" Click="TrayOpen_Click" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Quit" Click="TrayQuit_Click" />
                </MenuFlyout>
            </tb:TaskbarIcon.ContextFlyout>
        </tb:TaskbarIcon>
    </Grid>
</Window>
