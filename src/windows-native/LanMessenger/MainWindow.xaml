<Window
    x:Class="LanMessenger.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sidebar="using:LanMessenger.UI.Sidebar"
    xmlns:tb="using:H.NotifyIcon">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar pane -->
        <Grid Grid.Column="0"
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,0,1,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header: title on left, icon buttons on right — matches macOS toolbar placement -->
            <Grid Grid.Row="0" Padding="16,12,8,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Chats"
                           Style="{ThemeResource TitleTextBlockStyle}"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="2">
                    <Button x:Name="NewMessageBtn"
                            Width="36" Height="36"
                            Padding="0"
                            CornerRadius="18"
                            BorderThickness="0"
                            ToolTipService.ToolTip="New message"
                            Click="NewMessageBtn_Click">
                        <Button.Resources>
                            <SolidColorBrush x:Key="ButtonBackground"             Color="Transparent"/>
                            <StaticResource x:Key="ButtonBackgroundPointerOver"   ResourceKey="AppIconHoverBrush"/>
                            <StaticResource x:Key="ButtonBackgroundPressed"       ResourceKey="AppIconPressedBrush"/>
                            <SolidColorBrush x:Key="ButtonBorderBrush"            Color="Transparent"/>
                            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent"/>
                        </Button.Resources>
                        <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                  Glyph="&#xE932;"
                                  FontSize="16" />
                    </Button>
                    <Button x:Name="ContactsBtn"
                            Width="36" Height="36"
                            Padding="0"
                            CornerRadius="18"
                            BorderThickness="0"
                            ToolTipService.ToolTip="Contacts"
                            Click="ContactsBtn_Click">
                        <Button.Resources>
                            <SolidColorBrush x:Key="ButtonBackground"             Color="Transparent"/>
                            <StaticResource x:Key="ButtonBackgroundPointerOver"   ResourceKey="AppIconHoverBrush"/>
                            <StaticResource x:Key="ButtonBackgroundPressed"       ResourceKey="AppIconPressedBrush"/>
                            <SolidColorBrush x:Key="ButtonBorderBrush"            Color="Transparent"/>
                            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent"/>
                        </Button.Resources>
                        <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                  Glyph="&#xE77B;"
                                  FontSize="16" />
                    </Button>
                    <Button x:Name="SettingsBtn"
                            Width="36" Height="36"
                            Padding="0"
                            CornerRadius="18"
                            BorderThickness="0"
                            ToolTipService.ToolTip="Settings"
                            Click="SettingsBtn_Click">
                        <Button.Resources>
                            <SolidColorBrush x:Key="ButtonBackground"             Color="Transparent"/>
                            <StaticResource x:Key="ButtonBackgroundPointerOver"   ResourceKey="AppIconHoverBrush"/>
                            <StaticResource x:Key="ButtonBackgroundPressed"       ResourceKey="AppIconPressedBrush"/>
                            <SolidColorBrush x:Key="ButtonBorderBrush"            Color="Transparent"/>
                            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent"/>
                        </Button.Resources>
                        <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                  Glyph="&#xE713;"
                                  FontSize="16" />
                    </Button>
                </StackPanel>
            </Grid>

            <sidebar:SidebarControl x:Name="Sidebar"
                                    Grid.Row="1" />
        </Grid>

        <!-- Placeholder shown until a conversation is opened — previously this
             was a bare blank pane. Sits UNDER the ContentControl so it is
             covered automatically once content is set. -->
        <StackPanel x:Name="NoConversationState"
                    Grid.Column="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="10">
            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                      Glyph="&#xE8BD;"
                      FontSize="44"
                      Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
            <TextBlock Text="LAN Messenger"
                       HorizontalAlignment="Center"
                       Style="{ThemeResource SubtitleTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock Text="Select a conversation, or start a new one with the pencil button."
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       MaxWidth="300"
                       TextWrapping="Wrap"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
        </StackPanel>

        <!-- Content area -->
        <ContentControl x:Name="ContentFrame"
                        Grid.Column="1"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch" />

        <!-- System tray icon (lives off-screen but is rendered in the notification area) -->
        <tb:TaskbarIcon x:Name="TrayIcon"
                        ToolTipText="LAN Messenger"
                        NoLeftClickDelay="True"
                        IconSource="Assets/icon.ico"
                        LeftClickCommand="{x:Bind ShowFromTrayCommand, Mode=OneWay}">
            <tb:TaskbarIcon.ContextFlyout>
                <MenuFlyout>
                    <MenuFlyoutItem Text="Open LAN Messenger"
                                    Command="{x:Bind OpenFromTrayCommand, Mode=OneWay}" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Text="Quit"
                                    Command="{x:Bind QuitFromTrayCommand, Mode=OneWay}" />
                </MenuFlyout>
            </tb:TaskbarIcon.ContextFlyout>
        </tb:TaskbarIcon>
    </Grid>
</Window>
